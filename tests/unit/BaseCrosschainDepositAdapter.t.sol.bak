pragma solidity 0.8.28;

import { Test } from "forge-std/Test.sol";
import { BaseCrosschainDepositAdapter } from "../../src/adapters/BaseCrosschainDepositAdapter.sol";
import { ZapExecutor } from "../../src/adapters/ZapExecutor.sol";
import { ICrosschainDepositAdapter } from "../../src/interfaces/ICrosschainDepositAdapter.sol";
import { IElitraVault } from "../../src/interfaces/IElitraVault.sol";
import { IBalanceUpdateHook } from "../../src/interfaces/IBalanceUpdateHook.sol";
import { IRedemptionHook } from "../../src/interfaces/IRedemptionHook.sol";
import { ITransactionGuard } from "../../src/interfaces/ITransactionGuard.sol";
import { ERC20Mock } from "../mocks/ERC20Mock.sol";
import { Call } from "../../src/interfaces/IVaultBase.sol";

/// @notice Mock vault for testing - minimal implementation
contract MockVaultForAdapter is IElitraVault {
    ERC20Mock public override asset;
    mapping(address => uint256) private _balanceOf;

    constructor(ERC20Mock _asset) {
        asset = _asset;
    }

    // Exposed balanceOf for testing
    function userBalanceOf(address user) external view returns (uint256) {
        return _balanceOf[user];
    }

    // Minimal implementation for tests
    function deposit(uint256 amount, address receiver) external override returns (uint256) {
        asset.transferFrom(msg.sender, address(this), amount);
        uint256 shares = amount;
        _balanceOf[receiver] += shares;
        return shares;
    }

    function lastPricePerShare() external pure override returns (uint256) {
        return 1e18;
    }

    // Stub implementations for other interface methods
    function totalAssets() external pure override returns (uint256) { return 0; }
    function totalSupply() external pure override returns (uint256) { return 0; }
    function convertToShares(uint256) external pure override returns (uint256) { return 0; }
    function convertToAssets(uint256) external pure override returns (uint256) { return 0; }
    function maxDeposit(address) external pure override returns (uint256) { return type(uint256).max; }
    function maxMint(address) external pure override returns (uint256) { return type(uint256).max; }
    function maxWithdraw(address) external pure override returns (uint256) { return type(uint256).max; }
    function maxRedeem(address) external pure override returns (uint256) { return type(uint256).max; }
    function previewDeposit(uint256) external pure override returns (uint256) { return 0; }
    function previewMint(uint256) external pure override returns (uint256) { return 0; }
    function previewWithdraw(uint256) external pure override returns (uint256) { return 0; }
    function previewRedeem(uint256) external pure override returns (uint256) { return 0; }
    function mint(uint256, address) external pure override returns (uint256) { return 0; }
    function withdraw(uint256, address, address) external pure override returns (uint256) { return 0; }
    function redeem(uint256, address, address) external pure override returns (uint256) { return 0; }
    function name() external pure override returns (string memory) { return "Mock Vault"; }
    function symbol() external pure override returns (string memory) { return "MV"; }
    function decimals() external pure override returns (uint8) { return 18; }
    function allowance(address, address) external pure override returns (uint256) { return 0; }
    function approve(address, uint256) external pure override returns (bool) { return true; }
    function transfer(address, uint256) external pure override returns (bool) { return true; }
    function transferFrom(address, address, uint256) external pure override returns (bool) { return true; }
    function balanceOf(address) external pure override returns (uint256) { return 0; }

    // IElitraVault stubs
    function updateBalance(uint256) external override {}
    function setBalanceUpdateHook(IBalanceUpdateHook) external override {}
    function balanceUpdateHook() external pure override returns (IBalanceUpdateHook) { return IBalanceUpdateHook(address(0)); }
    function lastBlockUpdated() external pure override returns (uint256) { return 0; }
    function aggregatedUnderlyingBalances() external pure override returns (uint256) { return 0; }
    function navFreshnessThreshold() external pure override returns (uint256) { return 0; }
    function lastTimestampUpdated() external pure override returns (uint256) { return 0; }
    function setNavFreshnessThreshold(uint256) external override {}
    function setRedemptionHook(IRedemptionHook) external override {}
    function redemptionHook() external pure override returns (IRedemptionHook) { return IRedemptionHook(address(0)); }
    function getAvailableBalance() external pure override returns (uint256) { return 0; }
    function requestRedeem(uint256, address, address) external pure override returns (uint256) { return 0; }
    function fulfillRedeem(address, uint256) external override {}
    function cancelRedeem(address, uint256) external override {}
    function pendingRedeemRequest(address) external pure override returns (uint256) { return 0; }
    function manageBatchWithDelta(Call[] calldata, int256) external payable override {}
    function setDepositFee(uint256) external override {}
    function setWithdrawFee(uint256) external override {}
    function setQueuedRedeemFee(uint256) external override {}
    function setFeeRecipient(address) external override {}
    function claimFees() external override {}
    function feeOnDeposit() external pure override returns (uint256) { return 0; }
    function feeOnWithdraw() external pure override returns (uint256) { return 0; }
    function feeOnQueuedRedeem() external pure override returns (uint256) { return 0; }
    function feeRecipient() external pure override returns (address) { return address(0); }
    function guards(address) external pure override returns (ITransactionGuard) { return ITransactionGuard(address(0)); }
    function setGuard(address, address) external override {}
    function removeGuard(address) external override {}
    function setTrustedTarget(address, bool) external override {}
    function isTrustedTarget(address) external pure override returns (bool) { return false; }
    function getTrustedTargets() external pure override returns (address[] memory) { return new address[](0); }
    function getGuardedTargets() external pure override returns (address[] memory) { return new address[](0); }
    function manageBatch(Call[] calldata) external payable override {}
    function pause() external override {}
    function unpause() external override {}
}

/// @notice Mock adapter exposing internal functions
contract MockBaseAdapter is BaseCrosschainDepositAdapter {
    function initialize(
        address _owner,
        address _queue,
        address _zapExecutor
    ) external initializer {
        __BaseAdapter_init(_owner, _queue, _zapExecutor);
    }

    function exposedProcessReceivedFunds(
        address user,
        uint32 sourceId,
        address token,
        uint256 amount,
        bytes32 messageId,
        bytes memory payload
    ) external {
        _processReceivedFunds(user, sourceId, token, amount, messageId, payload);
    }

    function depositMock(address user, uint32 sourceId, address token, uint256 amount, address vaultAddr, bytes32 messageId) external {
        bytes memory payload = abi.encode(vaultAddr, user, uint256(0), new Call[](0));
        _processReceivedFunds(user, sourceId, token, amount, messageId, payload);
    }
}

contract BaseCrosschainDepositAdapter_Test is Test {
    MockBaseAdapter public adapter;
    ZapExecutor public zapExecutor;
    ERC20Mock public token;
    MockVaultForAdapter public vault;

    address public owner;
    address public queue;
    address public user;
    address public operator;

    function setUp() public {
        owner = makeAddr("owner");
        queue = makeAddr("queue");
        user = makeAddr("user");
        operator = makeAddr("operator");

        token = new ERC20Mock();
        vault = new MockVaultForAdapter(token);
        zapExecutor = new ZapExecutor();

        adapter = new MockBaseAdapter();
        adapter.initialize(owner, queue, address(zapExecutor));
    }

    function test_Initialize_SetsOwner() public {
        assertEq(adapter.owner(), owner);
    }

    function test_SetSupportedVault() public {
        address newVault = makeAddr("vault");

        vm.prank(owner);
        adapter.setSupportedVault(newVault, true);

        assertTrue(adapter.isVaultSupported(newVault));
    }

    function test_SetZapExecutor() public {
        address newZapExecutor = makeAddr("zapExecutor");

        vm.prank(owner);
        adapter.setZapExecutor(newZapExecutor);

        assertEq(address(adapter.zapExecutor()), newZapExecutor);
    }

    function test_Pause() public {
        vm.prank(owner);
        adapter.pause();

        assertTrue(adapter.paused());
    }

    function test_Unpause() public {
        vm.prank(owner);
        adapter.pause();

        vm.prank(owner);
        adapter.unpause();

        assertFalse(adapter.paused());
    }

    function test_Pause_OnlyOwnerOrOperator() public {
        vm.prank(owner);
        adapter.setOperator(operator);

        vm.prank(operator);
        adapter.pause();

        assertTrue(adapter.paused());
    }

    function test_Pause_RevertsWhenNotAuthorized() public {
        vm.expectRevert();
        vm.prank(user);
        adapter.pause();
    }

    function test_EmergencyRecover_Token() public {
        uint256 amount = 1000e6;
        token.mint(address(adapter), amount);

        address recipient = makeAddr("recipient");
        uint256 balanceBefore = token.balanceOf(recipient);

        vm.prank(owner);
        adapter.emergencyRecover(address(token), recipient, amount);

        assertEq(token.balanceOf(recipient), balanceBefore + amount);
    }

    function test_EmergencyRecover_Native() public {
        uint256 amount = 1 ether;
        vm.deal(address(adapter), amount);

        address payable recipient = payable(makeAddr("recipient"));
        uint256 balanceBefore = recipient.balance;

        vm.prank(owner);
        adapter.emergencyRecover(address(0), recipient, amount);

        assertEq(recipient.balance, balanceBefore + amount);
    }

    function test_EmergencyRecover_OnlyOwner() public {
        vm.expectRevert();
        vm.prank(user);
        adapter.emergencyRecover(address(token), user, 0);
    }

    function test_DepositMock_Success() public {
        uint256 amount = 1000e6;
        token.mint(user, amount);

        vm.prank(owner);
        adapter.setSupportedVault(address(vault), true);

        vm.prank(user);
        token.transfer(address(adapter), amount);

        bytes32 messageId = keccak256("message");
        adapter.depositMock(user, 1, address(token), amount, address(vault), messageId);

        (uint256 depositId, , , , , , , uint256 shares, , , ) = adapter.getDepositRecord(0);
        assertEq(depositId, 0);
        assertEq(shares, amount);
        assertEq(vault.balanceOf(user), amount);
    }

    function test_DepositMock_VaultNotSupported() public {
        uint256 amount = 1000e6;
        token.mint(address(adapter), amount);

        bytes32 messageId = keccak256("message");
        adapter.depositMock(user, 1, address(token), amount, address(vault), messageId);

        (, , , , , , , uint256 shares, ICrosschainDepositAdapter.DepositStatus status, , ) = adapter.getDepositRecord(0);
        assertEq(shares, 0);
        assertEq(uint256(status), uint256(ICrosschainDepositAdapter.DepositStatus.DepositFailed));
    }

    function test_GetDepositRecord() public {
        uint256 amount = 1000e6;
        token.mint(address(adapter), amount);

        vm.prank(owner);
        adapter.setSupportedVault(address(vault), true);

        bytes32 messageId = keccak256("message");
        adapter.depositMock(user, 1, address(token), amount, address(vault), messageId);

        ICrosschainDepositAdapter.DepositRecord memory record = adapter.getDepositRecord(0);
        assertEq(record.user, user);
        assertEq(record.amountIn, amount);
        assertEq(uint256(record.status), uint256(ICrosschainDepositAdapter.DepositStatus.Success));
    }

    function test_GetUserDepositIds() public {
        uint256 amount = 1000e6;
        token.mint(address(adapter), amount);

        vm.prank(owner);
        adapter.setSupportedVault(address(vault), true);

        bytes32 messageId = keccak256("message");
        adapter.depositMock(user, 1, address(token), amount, address(vault), messageId);

        uint256[] memory depositIds = adapter.getUserDepositIds(user);
        assertEq(depositIds.length, 1);
        assertEq(depositIds[0], 0);
    }

    function test_SetOperator() public {
        vm.prank(owner);
        adapter.setOperator(operator);

        assertTrue(adapter.hasRole(adapter.OPERATOR_ROLE(), operator));
    }

    function test_RemoveOperator() public {
        vm.prank(owner);
        adapter.setOperator(operator);

        vm.prank(owner);
        adapter.removeOperator(operator);

        assertFalse(adapter.hasRole(adapter.OPERATOR_ROLE(), operator));
    }

    function test_TransferOwnership() public {
        address newOwner = makeAddr("newOwner");

        vm.prank(owner);
        adapter.transferOwnership(newOwner);

        assertEq(adapter.owner(), newOwner);
        assertTrue(adapter.hasRole(adapter.DEFAULT_ADMIN_ROLE(), newOwner));
        assertTrue(adapter.hasRole(adapter.OPERATOR_ROLE(), newOwner));
        assertFalse(adapter.hasRole(adapter.DEFAULT_ADMIN_ROLE(), owner));
        assertFalse(adapter.hasRole(adapter.OPERATOR_ROLE(), owner));
    }
}
